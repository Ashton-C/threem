{
  "name": "threem",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test tests/unit/*.test.ts",
    "test:integration": "node --experimental-strip-types --env-file=.env.local --test tests/integration/*.test.ts",
    "test:scoring": "node --conditions=react-server --experimental-strip-types --env-file=.env.local scripts/consistency-test.ts",
    "test:gemma": "node --conditions=react-server --experimental-strip-types --env-file=.env.local scripts/gemma-test.ts",
    "seed:top50": "node --conditions=react-server --experimental-strip-types --env-file=.env.local scripts/seed-top50.ts",
    "seed:catalog": "node --conditions=react-server --experimental-strip-types --env-file=.env.local scripts/seed-catalog.ts",
    "seed:all": "npm run seed:top50 && npm run seed:catalog",
    "seed:steam": "node --conditions=react-server --experimental-strip-types --env-file=.env.local scripts/seed-steam.ts",
    "backfill:art": "node --conditions=react-server --experimental-strip-types --env-file=.env.local scripts/backfill-art.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.49.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.5",
    "@vercel/functions": "^3.7.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0"
  }
}
