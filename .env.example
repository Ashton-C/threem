# Copy to .env.local and fill in. NEVER commit .env.local.

# Supabase — project settings > API
SUPABASE_URL=                       # https://<ref>.supabase.co (no /rest/v1 path!)
SUPABASE_SERVICE_ROLE_KEY=          # sb_secret_... — server-side only, full write access

# Same project, browser-safe pair (auth + library). NEVER put the secret key here.
NEXT_PUBLIC_SUPABASE_URL=           # same as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # sb_publishable_... key

# Google AI Studio — aistudio.google.com (free tier)
GOOGLE_AI_API_SECRET=

# Upstash Redis — required in production for rate limiting (free tier: upstash.com)
# If unset, rate limiting is skipped (dev only — do not deploy publicly without it).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
